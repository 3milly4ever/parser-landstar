lay: table-cell; vertical-align: middle; float: left; width: 70%; } .columnTwo { display: table-cell; vertical-align: middle; float: right; width: 30%; text-align: right; } .internal { columns: 1 auto; align-items: start; margin: 1.5rem 2rem 0rem; width: auto; } .internal1 { margin-top: 1.5rem; }.content { padding: 0 25px; font-family: 'Roboto', sans-serif; margin: 0px; background-color: white; } body { width: 100%; background-color: #ededed; margin: 0; padding: 0; font-family:'Roboto', sans-serif} html { width: 100%; } table { border-collapse: collapse; mso-table-lspace: 0pt; mso-table-rspace: 0pt; } a { /* color: #4d4d4d; */ text-decoration: underline; } a.nav { color: #CC0000; text-decoration: underline; }.dataSection { display: flex; } .line { width: 100%; height: 10px; border-bottom: 1px solid #CCCECE; text-align: center; margin-top: 20px; margin-bottom: 45px; } .line2 { width: 100%; height: 10px; border-bottom: 1px solid #CCCECE; text-align: center; margin-top: 0px; margin-bottom: 1rem; } .column {box-sizing: border-box; padding: 10px; } .map-pin-delivery { background-image: url('https://www7.sylectus.com/images/circle-green.png'); left: -5px; }.map-pin-pick-up {background-image: url('https://www7.sylectus.com/images/circle-blue.png'); left: -5px; }.rightArrow{ background-repeat: no-repeat; height: 40px; width: 40px; position: relative; background-image: url('https://www7.sylectus.com/images/arrow-right.png'); }.map-pin-delivery{ background-repeat: no-repeat; top: 1px; display: inline-flex; height: 12px; width: 13px; flex-direction: row; margin-right: 5px; }.map-pin-pick-up { background-repeat: no-repeat; top: 1px; display: inline-flex; height: 12px; width: 13px; flex-direction: row; margin-right: 3px; }.column1 { width: 40%; background-color: #ffffff;line-height: 1.5; } .column2 { width: 20%; background-color: #ffffff; display: flex; justify-content: center; align-items: center; } .column3 { width: 40%; background-color: #ffffff;line-height: 1.5; } .column4 {